---
// /saas — v5 plan §4.2.
// Cost-driven migration story for SaaS / platform teams.
// Calculator CTA front-and-center; per-version compression table
// (verified, publishable today); migration playbook.

import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import MechanismExplanation from '../components/MechanismExplanation.astro';
import CompressionResultsTable from '../components/CompressionResultsTable.astro';
import { webPageSchema, breadcrumbListSchema } from '../lib/seo';

const title = 'DeltaGlider for SaaS — cut S3 storage cost on versioned artifacts';
const description =
  'Your CI ships a new build every commit. Most share 99% of their bytes. DeltaGlider stores the 1%. Same S3 API, same SDKs, same workflow. Open source, GPL-3.0.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="json-ld">
    <JsonLd schema={webPageSchema({ path: '/saas', title, description })} />
    <JsonLd
      schema={breadcrumbListSchema([
        { name: 'DeltaGlider', path: '/' },
        { name: 'For SaaS', path: '/saas' },
      ])}
    />
  </Fragment>
  <section class="shell hero">
    <h1>Stop paying AWS to store the same JAR a thousand times.</h1>

    <p class="hero-lede">
      Your CI pipeline ships a new build every commit. Most of those
      builds share 99% of their bytes with the previous one.
      DeltaGlider stores the 1% and reconstructs the rest. Same S3 API.
      Same SDKs. Same workflow.
    </p>

    <div class="hero-ctas">
      <a href="/pricing#calculator" class="btn btn-primary">See what it'd save you</a>
      <a href="/trial" class="btn">30-day trial</a>
      <a href="/docs/quickstart" class="btn">docker run</a>
    </div>
  </section>

  <div class="shell">
    <section class="in-progress">
      <h2>In progress: ReadonlyREST's build catalog → Hetzner</h2>

      <p>
        Beshu Tech is migrating its own ReadonlyREST build catalog off
        AWS S3 to Hetzner via DeltaGlider. The per-version compression
        results from the test runs are below.
      </p>

      <CompressionResultsTable detailed={false} />

      <p>
        Why is 1.38.0 only 4.1×? Because the legacy deltaspace mixes ES
        6, 7, and 8 Kibana plugins — structurally dissimilar artifacts
        in one prefix. The Delta Efficiency Panel correctly classifies
        it as "Fair, near Poor." We'd rather tell you that than gloss
        over it.
      </p>

      <p>→ <a href="/case-studies/readonlyrest-builds">Full case study</a></p>
    </section>

    <MechanismExplanation />

    <section class="playbook">
      <h2>What a migration looks like</h2>

      <ol>
        <li>
          Run DeltaGlider in your VPC. Point it at your existing AWS
          bucket — or a new Hetzner / Backblaze / Cloudflare bucket —
          anything S3-compatible.
        </li>
        <li>
          Use the Delta Efficiency Panel to scan a sample prefix.
          Verify compression is in the range that justifies migration.
        </li>
        <li>
          Stage migration bucket-by-bucket using per-bucket aliases
          and <code>quota=0</code> freeze mode during the window.
        </li>
        <li>
          Cut over your apps' S3 endpoint to DeltaGlider. SDKs
          unchanged.
        </li>
        <li>
          Run replication rules to mirror new writes to a DR region if
          you need one.
        </li>
      </ol>

      <p>
        Production support helps you with each of these. See
        <a href="/trial">/trial</a> for the 30-day try-the-relationship
        offer.
      </p>
    </section>

    <section class="cta">
      <h2>Next step</h2>
      <div class="hero-ctas">
        <a href="/pricing#calculator" class="btn btn-primary">Try the savings calculator</a>
        <a href="/trial" class="btn">Start a 30-day trial</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .in-progress,
  .playbook,
  .cta {
    margin: 3rem 0;
  }
</style>
