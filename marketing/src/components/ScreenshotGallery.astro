---
// ScreenshotGallery — visual proof of the admin UI.
// Per v5 §7 anti-polish: real screenshots, descriptive alt text, no decoration.

interface Screenshot {
  src: string;
  alt: string;
  caption: string;
}

const screenshots: Screenshot[] = [
  {
    src: '/screenshots/iam.jpg',
    alt: 'DeltaGlider admin UI showing the IAM user management page with users, groups, and permission policies',
    caption: 'Per-user IAM with ABAC permissions',
  },
  {
    src: '/screenshots/object-replication.jpg',
    alt: 'DeltaGlider admin UI showing replication rules between buckets, with run-now, pause, and delete-replication options',
    caption: 'Replication rules between buckets and backends',
  },
  {
    src: '/screenshots/advanced_security.jpg',
    alt: 'DeltaGlider admin UI showing the advanced security configuration page with encryption settings',
    caption: 'AES-256-GCM at-rest encryption',
  },
  {
    src: '/screenshots/analytics.jpg',
    alt: 'DeltaGlider admin UI showing storage analytics with compression ratios and stored-footprint breakdown',
    caption: 'Storage analytics — compression ratios live',
  },
  {
    src: '/screenshots/bucket-policies.jpg',
    alt: 'DeltaGlider admin UI showing per-bucket policy configuration including quotas and aliases',
    caption: 'Per-bucket policy, quotas, and aliases',
  },
  {
    src: '/screenshots/filebrowser.jpg',
    alt: 'DeltaGlider admin UI showing the object browser with files in a bucket',
    caption: 'Object browser with download and preview',
  },
];
---

<div class="screenshot-gallery">
  {
    screenshots.map((s) => (
      <figure class="screenshot-tile">
        <div class="screenshot-frame">
          <img
            src={s.src}
            alt={s.alt}
            width="1147"
            height="1440"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption>{s.caption}</figcaption>
      </figure>
    ))
  }
</div>

<style>
  .screenshot-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }

  @media (min-width: 600px) {
    .screenshot-gallery {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1000px) {
    .screenshot-gallery {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .screenshot-tile {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .screenshot-frame {
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-soft);
    box-shadow: var(--shadow-sm);
    transition: transform 0.12s ease, box-shadow 0.18s ease;
  }

  .screenshot-frame:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .screenshot-frame img {
    width: 100%;
    height: auto;
    display: block;
  }

  figcaption {
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.4;
    text-align: center;
  }
</style>
