---
interface Props {
  quote: string;
  name: string;
  title: string;
  about: string;
}

const { quote, name, title, about } = Astro.props;
---

<article class="testimonial-card">
  <span class="product-chip">About {about}</span>
  <p class="testimonial-quote">
    <span class="testimonial-quote-mark" aria-hidden="true">“</span>{quote}
  </p>
  <div class="testimonial-attr">
    <strong>{name}</strong>
    <span class="testimonial-title">{title}</span>
  </div>
</article>

<style>
  .testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .testimonial-quote {
    margin: 0;
    color: var(--ink);
    font-size: 1.02rem;
    line-height: 1.55;
    position: relative;
    max-width: none;
  }

  .testimonial-quote-mark {
    color: var(--brand);
    font-size: 1.5rem;
    line-height: 1;
    margin-right: 0.15rem;
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 700;
  }

  .testimonial-attr {
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--rule);
    font-size: 0.88rem;
    color: var(--ink-soft);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .testimonial-attr strong {
    color: var(--ink);
    font-weight: 600;
  }

  .testimonial-title {
    color: var(--ink-faint);
  }
</style>
